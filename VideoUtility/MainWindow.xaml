<Window x:Class="VideoUtility.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoUtility"
        xmlns:Controals="clr-namespace:VideoUtility.View.Controals"
        mc:Ignorable="d"
        Title="Video Utility" Height="700" Width="505"
        ResizeMode="NoResize"
        >
    <Grid>
        <TabControl FontSize="20">
            <TabItem Header="Applay Preset">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- row 0 -->
                    <Button Name="selectVideoButton" HorizontalAlignment="Left" Content="Select Video" Margin="5,5,0,5" Padding="5"/>
                    <Label Name="videoPathLabel" Content="No Video Selected" HorizontalAlignment="Left" Margin="130,5,0,5" Grid.ColumnSpan="2"/>

                    <!-- row 1 -->
                    <Label Grid.Row="1" Content="Select Preset" VerticalAlignment="Center" Grid.ColumnSpan="2"/>
                    <ComboBox Name="applyPresetComboBox" Grid.Row="1" Margin="130,10,10,10" SelectedIndex="0" HorizontalContentAlignment="Center" Grid.ColumnSpan="2"/>

                    <!-- row 2 -->
                    <Controals:Message Grid.Row="2" x:Name="messageControl"/>

                    <!-- row 3 -->
                    <Button Name="applyButton" Content="Apply" HorizontalAlignment="Right" VerticalAlignment="Bottom" Grid.Row="3" Width="100" Margin="0,0,10,10" Grid.Column="1"/>

                </Grid>
            </TabItem>
            <TabItem Header="Edit Preset">
                <Grid Name="editPresetGrid" Background="White" TextBox.TextChanged="EditPresetGrid_ValueChanged" ComboBox.SelectionChanged="EditPresetGrid_ValueChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Content="Preset" VerticalAlignment="Center"/>
                    <ComboBox Name="presetComboBox" Margin="65,10,10,10" SelectedIndex="0" />

                    <Label Content="Suffix" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBox Name="suffixTextBox" Grid.Row="1" Margin="65,10,10,10" Width="200" HorizontalAlignment="Left"/>
                    <Label Content="Cuts" Grid.Row="1" VerticalAlignment="Center" Margin="265,0,0,0"/>
                    <Controals:IntInputControl x:Name="CutsInput" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="330,0,0,0" Width="80"/>

                    <Label Content="Encoder" Grid.Row="2" VerticalAlignment="Center"/>
                    <ComboBox Name="encoderComboBox" Grid.Row="2" Margin="85,10,10,10" Width="180" HorizontalAlignment="Left" SelectedIndex="0"/>
                    <ComboBox Name="gpuEncoderComboBox" Grid.Row="2" HorizontalAlignment="Left" Width="150" Margin="280,10,10,10" SelectedIndex="0" Visibility="Hidden"/>

                    <Label Content="Encoder Preset" Grid.Row="3" VerticalAlignment="Center"/>
                    <ComboBox Name="encoderPresetComboBox" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Left" Width="200" Margin="150,10,10,10" SelectedIndex="0"/>
                    <Label Content="CRF" Grid.Row="3" VerticalAlignment="Center" Margin="350,0,0,0"/>
                    <Controals:IntInputControl x:Name="CRFInput" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="400,0,0,0" Width="80"/>

                    <Label Content="Format" Grid.Row="4" VerticalAlignment="Center"/>
                    <ComboBox Name="formatComboBox" Grid.Row="4" Margin="85,10,10,10" Width="200" HorizontalAlignment="Left" SelectedIndex="0" />

                    <Label Grid.Row="5" Content="Audio" VerticalAlignment="Center"/>
                    <ComboBox Name="audioComboBox" Grid.Row="5" Margin="65,10,0,10" Width="200" HorizontalAlignment="Left" SelectedIndex="0" />

                    <Button Name="addButton" Content="Add" HorizontalAlignment="Right" VerticalAlignment="Bottom" Grid.Row="6" Width="100" Margin="10"/>
                    <Button Name="saveButton" Content="Save" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="DarkRed" Foreground="White" BorderBrush="Red" 
                            Grid.Row="6" Width="100" Margin="10,10,120,10" Visibility="Hidden"/>
                    <Button Name="renameButton" Content="Rename" HorizontalAlignment="Left" VerticalAlignment="Bottom" Grid.Row="6" Width="100" Margin="10,10,110,10"/>
                    <Button Name="deleteButton" Content="Delete" HorizontalAlignment="Left" VerticalAlignment="Bottom" Grid.Row="6" Width="100" Margin="120,10,110,10"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
