<Window x:Class="VideoUtility.View.Dialog.ProgressBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoUtility.View.Dialog"
        mc:Ignorable="d"
        Title="Progress" Height="80" Width="600"        
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        >
    <Grid>
        <Rectangle  Fill="#1f1f1f" Margin="2"/>
        <Rectangle x:Name="bar" Fill="red" HorizontalAlignment="Left" Width="0" Margin="5"/>
    </Grid>
</Window>
