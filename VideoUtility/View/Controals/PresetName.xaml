<UserControl x:Class="VideoUtility.View.Controals.StringInputWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VideoUtility.View.Controals"
             mc:Ignorable="d" 
             d:DesignHeight="140" d:DesignWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <TextBox Name="presetNameTextBox" Margin="10,10,10,10" Grid.Row="0" VerticalContentAlignment="Center" Padding="10" Width="550" FontSize="20"/>
        <Button Name="okButton" Content="OK" Grid.Row="2" HorizontalAlignment="Right" Margin="10,10,10,10" Width="60" FontSize="20"/>
        <Button Name="cancelButton" Content="cacel" Grid.Row="2" HorizontalAlignment="Right" Margin="10,10,80,10" Width="80" FontSize="20"/>
    </Grid>
</UserControl>
