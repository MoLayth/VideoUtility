<UserControl x:Class="VideoUtility.View.Controals.IntInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VideoUtility.View.Controals"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="80">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Button Name="decreaseButton" Content="&lt;" FontSize="20"/>
        <Button Name="increaseButton" Content="&gt;" FontSize="20" Grid.Column="2"/>

        <Label Name="valueLabel" Content="0" FontSize="20" Grid.Column="1" Background="White" 
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="Black"/>
    </Grid>
</UserControl>
